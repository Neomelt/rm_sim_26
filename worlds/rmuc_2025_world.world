<?xml version='1.0' encoding='utf-8'?>
<sdf version='1.7'>
  <world name='default'>

    <gui fullscreen='0'>
      <plugin filename='MinimalScene' name='3D View'>
        <gz-gui>
          <title>3D View</title>
          <property type='bool' key='showTitleBar'>false</property>
          <property type='string' key='state'>docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.4 0.4 0.4</ambient_light>
        <background_color>0.8 0.8 0.8</background_color>
        <camera_pose>14.5 8 28 0 1.57 1.57</camera_pose>
      </plugin>

      <!-- 场景管理器：将仿真状态同步到渲染场景 -->
      <plugin filename='GzSceneManager' name='Scene Manager'>
        <gz-gui>
          <property type='bool' key='showTitleBar'>false</property>
          <property type='string' key='state'>docked</property>
        </gz-gui>
      </plugin>

      <!-- 鼠标交互视角控制 -->
      <plugin filename='InteractiveViewControl' name='Interactive view control'>
        <gz-gui>
          <property type='bool' key='showTitleBar'>false</property>
          <property type='string' key='state'>docked</property>
        </gz-gui>
      </plugin>

      <!-- 仿真控制：播放/暂停/步进 -->
      <plugin filename='WorldControl' name='World control'>
        <gz-gui>
          <title>World control</title>
          <property type='bool' key='showTitleBar'>false</property>
          <property type='string' key='state'>floating</property>
          <property type='double' key='x'>0</property>
          <property type='double' key='y'>0</property>
          <property type='double' key='width'>250</property>
          <property type='double' key='height'>50</property>
        </gz-gui>
        <play_pause>true</play_pause>
        <step>true</step>
        <start_paused>false</start_paused>
      </plugin>

      <!-- 仿真统计信息 -->
      <plugin filename='WorldStats' name='World stats'>
        <gz-gui>
          <title>World stats</title>
          <property type='bool' key='showTitleBar'>false</property>
          <property type='string' key='state'>floating</property>
          <property type='double' key='x'>250</property>
          <property type='double' key='y'>0</property>
          <property type='double' key='width'>250</property>
          <property type='double' key='height'>50</property>
        </gz-gui>
        <sim_time>true</sim_time>
        <real_time>true</real_time>
        <real_time_factor>true</real_time_factor>
        <iterations>false</iterations>
      </plugin>
    </gui>

    <!-- Global RGL scene manager required to upload meshes to GPU -->
    <plugin name='rgl::RGLServerPluginManager' filename='RGLServerPluginManager'>
      <do_ignore_entities_in_lidar_link>true</do_ignore_entities_in_lidar_link>
    </plugin>

    <!-- Physics -->
    <plugin filename="libgz-sim-physics-system.so" name="gz::sim::systems::Physics">
    </plugin>

    <!-- Forwards simulation state to the GUI -->
    <plugin filename="libgz-sim-scene-broadcaster-system.so" name="gz::sim::systems::SceneBroadcaster">
    </plugin>

    <!-- Processes user commands, like translate and create -->
    <plugin filename="libgz-sim-user-commands-system.so" name="gz::sim::systems::UserCommands">
    </plugin>

    <!-- Generates rendering sensor data -->
    <plugin filename="libgz-sim-sensors-system.so" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <plugin filename="libgz-sim-imu-system.so" name="gz::sim::systems::Imu">
    </plugin>


    <light type='directional' name='direct_light'>
      <visualize>false</visualize>
      <cast_shadows>true</cast_shadows>
      <pose>14.6 7.9 10 0 0 0</pose>
      <diffuse>1.0 1.0 1.0 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>0 0 -1</direction>
    </light>

    <model name='rmuc_2025'>
      <include>
        <uri>model://rmuc_2025</uri>
      </include>
      <pose>0.0 0.0 0 0 0 0</pose>
      <static>true</static>
    </model>
  </world>
</sdf>
