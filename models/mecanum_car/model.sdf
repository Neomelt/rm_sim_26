<?xml version="1.0" ?>
<sdf version="1.7">
  <model name="mecanum_robot" xmlns:gz="http://gazebosim.org/schema">

    <!-- ========== rmoss 风格: chassis origin 在轮轴高度 ========== -->

    <!-- BASE FOOTPRINT (虚拟链接, 用于里程计) -->
    <link name="body">
      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>0.001</ixx>
          <iyy>0.001</iyy>
          <izz>0.001</izz>
        </inertia>
      </inertial>
    </link>

    <!-- CHASSIS (origin 在轮轴高度, mesh 从底部向上渲染) -->
    <link name="chassis">
      <pose relative_to="body">0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0.12 0 0 0</pose>
        <mass>15.0</mass>
        <inertia>
          <ixx>0.295</ixx>
          <iyy>0.645</iyy>
          <izz>0.850</izz>
        </inertia>
      </inertial>
      <visual name="chassis_visual">
        <geometry>
          <mesh>
            <uri>model://mecanum_car/meshes/chassis_base.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="chassis_collision">
        <pose>0 0 0.12 0 0 0</pose>
        <geometry>
          <box>
            <size>0.48 0.36 0.20</size>
          </box>
        </geometry>
      </collision>

      <!-- 底盘 IMU 传感器 -->
      <sensor name="chassis_imu" type="imu">
        <pose>0 0 0.12 0 0 0</pose>
        <update_rate>200</update_rate>
        <always_on>true</always_on>
        <topic>chassis/imu</topic>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <joint name="body_to_chassis" type="fixed">
      <parent>body</parent>
      <child>chassis</child>
    </joint>

    <!-- ========== 装甲板模块 (rmoss rm21_armor_module 风格, 竖灯条) ========== -->

    <!-- 前装甲板 (+X 面) -->
    <link name="armor_front">
      <pose relative_to="chassis">0.243 0 0.10 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.00001</izz>
        </inertia>
      </inertial>
      <visual name="armor_visual">
        <geometry>
          <box><size>0.012 0.135 0.125</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
      <visual name="light_bar_left">
        <pose>0.007 0.060 0 0 0 0</pose>
        <geometry>
          <box><size>0.006 0.010 0.100</size></box>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>
          <diffuse>1.0 0.0 0.0 1</diffuse>
          <emissive>0.8 0.0 0.0 1</emissive>
        </material>
      </visual>
      <visual name="light_bar_right">
        <pose>0.007 -0.060 0 0 0 0</pose>
        <geometry>
          <box><size>0.006 0.010 0.100</size></box>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>
          <diffuse>1.0 0.0 0.0 1</diffuse>
          <emissive>0.8 0.0 0.0 1</emissive>
        </material>
      </visual>
      <collision name="armor_collision">
        <geometry>
          <box><size>0.012 0.135 0.125</size></box>
        </geometry>
      </collision>
    </link>
    <joint name="armor_front_joint" type="fixed">
      <parent>chassis</parent>
      <child>armor_front</child>
    </joint>

    <!-- 后装甲板 (-X 面) -->
    <link name="armor_rear">
      <pose relative_to="chassis">-0.243 0 0.10 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.00001</izz>
        </inertia>
      </inertial>
      <visual name="armor_visual">
        <geometry>
          <box><size>0.012 0.135 0.125</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
      <visual name="light_bar_left">
        <pose>-0.007 0.060 0 0 0 0</pose>
        <geometry>
          <box><size>0.006 0.010 0.100</size></box>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>
          <diffuse>1.0 0.0 0.0 1</diffuse>
          <emissive>0.8 0.0 0.0 1</emissive>
        </material>
      </visual>
      <visual name="light_bar_right">
        <pose>-0.007 -0.060 0 0 0 0</pose>
        <geometry>
          <box><size>0.006 0.010 0.100</size></box>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>
          <diffuse>1.0 0.0 0.0 1</diffuse>
          <emissive>0.8 0.0 0.0 1</emissive>
        </material>
      </visual>
      <collision name="armor_collision">
        <geometry>
          <box><size>0.012 0.135 0.125</size></box>
        </geometry>
      </collision>
    </link>
    <joint name="armor_rear_joint" type="fixed">
      <parent>chassis</parent>
      <child>armor_rear</child>
    </joint>

    <!-- 左装甲板 (+Y 面) -->
    <link name="armor_left">
      <pose relative_to="chassis">0 0.184 0.10 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.00001</izz>
        </inertia>
      </inertial>
      <visual name="armor_visual">
        <geometry>
          <box><size>0.135 0.012 0.125</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
      <visual name="light_bar_front">
        <pose>0.060 0.007 0 0 0 0</pose>
        <geometry>
          <box><size>0.010 0.006 0.100</size></box>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>
          <diffuse>1.0 0.0 0.0 1</diffuse>
          <emissive>0.8 0.0 0.0 1</emissive>
        </material>
      </visual>
      <visual name="light_bar_back">
        <pose>-0.060 0.007 0 0 0 0</pose>
        <geometry>
          <box><size>0.010 0.006 0.100</size></box>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>
          <diffuse>1.0 0.0 0.0 1</diffuse>
          <emissive>0.8 0.0 0.0 1</emissive>
        </material>
      </visual>
      <collision name="armor_collision">
        <geometry>
          <box><size>0.135 0.012 0.125</size></box>
        </geometry>
      </collision>
    </link>
    <joint name="armor_left_joint" type="fixed">
      <parent>chassis</parent>
      <child>armor_left</child>
    </joint>

    <!-- 右装甲板 (-Y 面) -->
    <link name="armor_right">
      <pose relative_to="chassis">0 -0.184 0.10 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.00001</izz>
        </inertia>
      </inertial>
      <visual name="armor_visual">
        <geometry>
          <box><size>0.135 0.012 0.125</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
      <visual name="light_bar_front">
        <pose>0.060 -0.007 0 0 0 0</pose>
        <geometry>
          <box><size>0.010 0.006 0.100</size></box>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>
          <diffuse>1.0 0.0 0.0 1</diffuse>
          <emissive>0.8 0.0 0.0 1</emissive>
        </material>
      </visual>
      <visual name="light_bar_back">
        <pose>-0.060 -0.007 0 0 0 0</pose>
        <geometry>
          <box><size>0.010 0.006 0.100</size></box>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>
          <diffuse>1.0 0.0 0.0 1</diffuse>
          <emissive>0.8 0.0 0.0 1</emissive>
        </material>
      </visual>
      <collision name="armor_collision">
        <geometry>
          <box><size>0.135 0.012 0.125</size></box>
        </geometry>
      </collision>
    </link>
    <joint name="armor_right_joint" type="fixed">
      <parent>chassis</parent>
      <child>armor_right</child>
    </joint>

    <!-- ========== 轮子 (rmoss 风格: Z=0, 碰撞/惯量旋转对齐 Y 轴) ========== -->

    <!-- 前左轮 (FL) - 麦轮 left -->
    <link name="front_left_wheel_link">
      <pose relative_to="chassis">0.20 0.21 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 1.5707 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0005</ixx>
          <iyy>0.001</iyy>
          <izz>0.0005</izz>
        </inertia>
      </inertial>
      <visual name="wheel_visual">
        <geometry>
          <mesh>
            <uri>model://mecanum_car/meshes/wheel_left.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="wheel_collision">
        <pose>0 0 0 1.5707 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.076</radius>
            <length>0.045</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.0</mu2>
              <fdir1 gz:expressed_in="chassis">1 -1 0</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>front_left_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <!-- 前右轮 (FR) - 麦轮 right -->
    <link name="front_right_wheel_link">
      <pose relative_to="chassis">0.20 -0.21 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 1.5707 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0005</ixx>
          <iyy>0.001</iyy>
          <izz>0.0005</izz>
        </inertia>
      </inertial>
      <visual name="wheel_visual">
        <geometry>
          <mesh>
            <uri>model://mecanum_car/meshes/wheel_right.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="wheel_collision">
        <pose>0 0 0 1.5707 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.076</radius>
            <length>0.045</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.0</mu2>
              <fdir1 gz:expressed_in="chassis">1 1 0</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>front_right_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <!-- 后左轮 (RL) - 麦轮 right (对角线对称) -->
    <link name="rear_left_wheel_link">
      <pose relative_to="chassis">-0.20 0.21 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 1.5707 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0005</ixx>
          <iyy>0.001</iyy>
          <izz>0.0005</izz>
        </inertia>
      </inertial>
      <visual name="wheel_visual">
        <geometry>
          <mesh>
            <uri>model://mecanum_car/meshes/wheel_right.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="wheel_collision">
        <pose>0 0 0 1.5707 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.076</radius>
            <length>0.045</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.0</mu2>
              <fdir1 gz:expressed_in="chassis">1 1 0</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>rear_left_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <!-- 后右轮 (RR) - 麦轮 left (对角线对称) -->
    <link name="rear_right_wheel_link">
      <pose relative_to="chassis">-0.20 -0.21 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 1.5707 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0005</ixx>
          <iyy>0.001</iyy>
          <izz>0.0005</izz>
        </inertia>
      </inertial>
      <visual name="wheel_visual">
        <geometry>
          <mesh>
            <uri>model://mecanum_car/meshes/wheel_left.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="wheel_collision">
        <pose>0 0 0 1.5707 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.076</radius>
            <length>0.045</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.0</mu2>
              <fdir1 gz:expressed_in="chassis">1 -1 0</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>rear_right_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <!-- ========== LIDAR ========== -->
    <link name="livox_lidar">
      <pose relative_to="chassis">0.20 0 0.253 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.001</ixx>
          <iyy>0.001</iyy>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="lidar_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>

      <!-- LIDAR SENSOR (RGL) -->
      <sensor name="RGLLidar" type="custom">
        <plugin filename="RGLServerPluginInstance" name="rgl::RGLServerPluginInstance">
          <range>
            <min>0.05</min>
            <max>245</max>
          </range>
          <update_rate>10</update_rate>
          <update_on_paused_sim>false</update_on_paused_sim>
          <topic>livox/lidar</topic>
          <frame>livox_lidar</frame>
          <pattern_preset_path>__RM_SIM_26_PATTERN_PRESET_PATH__</pattern_preset_path>
        </plugin>
      </sensor>

      <!-- IMU SENSOR (Livox 内置) -->
      <sensor name="livox_lidar_imu" type="imu">
        <update_rate>100</update_rate>
        <always_on>true</always_on>
        <topic>/livox/imu</topic>
        <frame>livox_lidar</frame>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>
    <joint name="lidar_joint" type="fixed">
      <parent>chassis</parent>
      <child>livox_lidar</child>
    </joint>

    <!-- ========== 云台模块 ========== -->

    <!-- 云台偏航轴 (Yaw) -->
    <link name="gimbal_yaw">
      <pose relative_to="chassis">0 0 0.205 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.003</ixx>
          <iyy>0.003</iyy>
          <izz>0.003</izz>
        </inertia>
      </inertial>
      <visual name="gimbal_yaw_visual">
        <geometry>
          <mesh>
            <uri>model://mecanum_car/meshes/gimbal_yaw.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="gimbal_yaw_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
      </collision>
    </link>
    <joint name="gimbal_yaw_joint" type="revolute">
      <parent>chassis</parent>
      <child>gimbal_yaw</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159</lower>
          <upper>3.14159</upper>
          <effort>10</effort>
          <velocity>3.14</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <!-- 云台俯仰轴 (Pitch) -->
    <link name="gimbal_pitch">
      <pose relative_to="gimbal_yaw">0.06 0 0.08 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.001</ixx>
          <iyy>0.002</iyy>
          <izz>0.002</izz>
        </inertia>
      </inertial>
      <visual name="gimbal_pitch_visual">
        <geometry>
          <mesh>
            <uri>model://mecanum_car/meshes/gimbal_pitch.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="gimbal_pitch_collision">
        <geometry>
          <box>
            <size>0.10 0.08 0.06</size>
          </box>
        </geometry>
      </collision>
    </link>
    <joint name="gimbal_pitch_joint" type="revolute">
      <parent>gimbal_yaw</parent>
      <child>gimbal_pitch</child>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit>
          <lower>-0.785398</lower>
          <upper>0.785398</upper>
          <effort>10</effort>
          <velocity>2.0</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <!-- 摄像头 -->
    <link name="camera">
      <pose relative_to="gimbal_pitch">0.08 0 0 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <iyy>0.0001</iyy>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <visual name="camera_visual">
        <geometry>
          <box>
            <size>0.06 0.04 0.04</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <collision name="camera_collision">
        <geometry>
          <box>
            <size>0.06 0.04 0.04</size>
          </box>
        </geometry>
      </collision>
      <sensor name="camera" type="camera">
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
        </camera>
      </sensor>
    </link>
    <joint name="camera_joint" type="fixed">
      <parent>gimbal_pitch</parent>
      <child>camera</child>
    </joint>

    <!-- ========== 插件 ========== -->

    <!-- MECANUM DRIVE -->
    <plugin filename="gz-sim-mecanum-drive-system" name="gz::sim::systems::MecanumDrive">
      <front_left_joint>front_left_wheel_joint</front_left_joint>
      <front_right_joint>front_right_wheel_joint</front_right_joint>
      <back_left_joint>rear_left_wheel_joint</back_left_joint>
      <back_right_joint>rear_right_wheel_joint</back_right_joint>
      <wheel_separation>0.42</wheel_separation>
      <wheelbase>0.40</wheelbase>
      <wheel_radius>0.076</wheel_radius>
      <topic>/cmd_vel</topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>body</child_frame_id>
    </plugin>

    <!-- 云台控制 -->
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>gimbal_yaw_joint</joint_name>
      <topic>/gimbal/yaw/cmd_pos</topic>
      <p_gain>10</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.5</d_gain>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>gimbal_pitch_joint</joint_name>
      <topic>/gimbal/pitch/cmd_pos</topic>
      <p_gain>10</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.5</d_gain>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
      <joint_name>gimbal_yaw_joint</joint_name>
      <joint_name>gimbal_pitch_joint</joint_name>
    </plugin>

    <!-- Pose Publisher for TF -->
    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <publish_collision_pose>false</publish_collision_pose>
      <publish_visual_pose>false</publish_visual_pose>
      <publish_nested_model_pose>true</publish_nested_model_pose>
    </plugin>

  </model>
</sdf>
